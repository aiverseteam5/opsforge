# OpsForge environment configuration template.
# Copy to .env and fill in real values before starting the server.
# IMPORTANT: Set OPSFORGE_ENVIRONMENT=production for any non-local deployment —
# this activates the startup validator that enforces all required secrets below.

# ── Required in production ─────────────────────────────────────────────────────

# Deployment mode. "dev" silences secret-presence checks and enables HMAC bypass
# stubs. Always "production" outside your laptop.
OPSFORGE_ENVIRONMENT=production

# PostgreSQL connection string (psycopg3 async driver).
OPSFORGE_DATABASE_URL=postgresql+psycopg://opsforge:changeme@localhost:5432/opsforge

# Fernet master key — encrypts all connector credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OPSFORGE_FERNET_KEY=

# HMAC secret for inbound alert/change webhook verification.
# Generate: openssl rand -hex 32
OPSFORGE_WEBHOOK_SECRET=

# ── LLM provider ───────────────────────────────────────────────────────────────

# Any litellm-routable model id (cloud, self-hosted OpenAI-compatible, local).
OPSFORGE_MODEL=claude-sonnet-4-6
OPSFORGE_EMBEDDING_MODEL=text-embedding-3-small

# LLM API key — used ONLY in dev (OPSFORGE_DEV_LLM_FALLBACK=true).
# In production, configure a vault provider via the API instead.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Local-dev LLM fallback: when true, picks up the env key above if no vault
# provider is configured. Must be false in production.
OPSFORGE_DEV_LLM_FALLBACK=false

# ── Slack surface (optional) ───────────────────────────────────────────────────

# Bot token (xoxb-...) for posting run reports to Slack.
OPSFORGE_SLACK_BOT_TOKEN=

# Signing secret for verifying inbound Slack events/commands/interactivity.
# REQUIRED when OPSFORGE_SLACK_BOT_TOKEN is set in production — the startup
# validator will refuse to start without it.
OPSFORGE_SLACK_SIGNING_SECRET=

# Channel for codified-skill review notifications (e.g. #opsforge-reviews).
OPSFORGE_SKILL_REVIEW_CHANNEL=

# ── Tuning (optional overrides) ────────────────────────────────────────────────

# Graph sync: re-sync connector topology this often (seconds). Default 10 min.
# OPSFORGE_GRAPH_SYNC_INTERVAL_S=600

# Run dispatch rate limit (per API token): max requests per window.
# OPSFORGE_RUN_DISPATCH_RATE_LIMIT_REQUESTS=60
# OPSFORGE_RUN_DISPATCH_RATE_LIMIT_WINDOW_S=60

# Webhook rate limit (per source IP).
# OPSFORGE_WEBHOOK_RATE_LIMIT_REQUESTS=120
# OPSFORGE_WEBHOOK_RATE_LIMIT_WINDOW_S=60

# JIT credential lease TTL (seconds). Default 1 hour.
# OPSFORGE_JIT_LEASE_TTL_S=3600

# Minimum clean executions before a tool can be graduated to auto_with_notify.
# OPSFORGE_GRADUATION_MIN_EXECUTIONS=3

# API server bind address / port.
# OPSFORGE_API_HOST=0.0.0.0
# OPSFORGE_API_PORT=8080

# Log level: DEBUG | INFO | WARNING | ERROR
# OPSFORGE_LOG_LEVEL=INFO
